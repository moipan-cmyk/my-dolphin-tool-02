{
  "module": "fastboot",
  "version": "1.0.0",
  "functions": {
    "read_info": {
      "type": "fastboot_command",
      "description": "Get device info via fastboot",
      "progress_steps": [
        {"percent": 0, "message": "Waiting for Fastboot Device..."}
      ],
      "command": "fastboot getvar all",
      "filter_keywords": {
        "product": "Product",
        "version": "Version",
        "serialno": "Serial Number",
        "secure": "Secure Boot",
        "unlocked": "Unlocked"
      },
      "success_message": "Fastboot info read complete",
      "requires_device": true
    },
    
    "factory_reset": {
      "type": "fastboot_sequence",
      "description": "Perform factory reset via fastboot",
      "progress_steps": [
        {"percent": 0, "message": "Starting Fastboot Factory Reset..."}
      ],
      "commands": [
        {"step": "Erasing system", "cmd": "fastboot erase system"},
        {"step": "Erasing userdata", "cmd": "fastboot erase userdata"},
        {"step": "Erasing cache", "cmd": "fastboot erase cache"},
        {"step": "Rebooting", "cmd": "fastboot reboot"}
      ],
      "success_message": "Factory reset complete",
      "requires_device": true
    },
    
    "frp": {
      "type": "fastboot_command",
      "description": "Unlock FRP via fastboot",
      "progress_steps": [
        {"percent": 0, "message": "Starting FRP Unlock..."}
      ],
      "command": "fastboot erase frp",
      "success_message": "FRP unlock complete",
      "requires_device": true
    },
    
    "change_slot": {
      "type": "fastboot_command",
      "description": "Change active boot slot",
      "progress_steps": [
        {"percent": 0, "message": "Changing boot slot..."}
      ],
      "command": "fastboot set_active a",
      "success_message": "Boot slot changed",
      "requires_device": true
    },
    
    "exit_bootloader": {
      "type": "fastboot_command",
      "description": "Exit bootloader mode",
      "progress_steps": [
        {"percent": 0, "message": "Exiting bootloader..."}
      ],
      "command": "fastboot reboot",
      "success_message": "Device rebooting from bootloader",
      "requires_device": true
    }
  }
}
{
  "module": "adb",
  "version": "1.0.0",
  "functions": {
    "read_info": {
      "type": "adb_commands",
      "description": "Read device information",
      "requires_device": true,
      "device_type": "adb",
      "progress_steps": [
        {"percent": 5, "message": "🔍 Reading device information..."},
        {"percent": 20, "message": "📱 ADB connection established"},
        {"percent": 30, "message": "📡 Fetching device properties..."},
        {"percent": 50, "message": "📊 Parsing device information..."},
        {"percent": 70, "message": "✅ Processing complete"}
      ],
      "commands": [
        "adb shell getprop ro.product.model",
        "adb shell getprop ro.product.manufacturer",
        "adb shell getprop ro.build.version.release",
        "adb shell getprop ro.product.board",
        "adb shell getprop ro.build.display.id"
      ],
      "filter_keywords": {
        "ro.product.model": "Model",
        "ro.product.manufacturer": "Manufacturer",
        "ro.build.version.release": "Android Version",
        "ro.product.board": "Platform",
        "ro.build.display.id": "Build"
      },
      "success_message": "✅ Device information retrieved successfully",
      "error_message": "❌ Failed to read device info"
    },
    
    "reboot_bootloader": {
      "type": "adb_command",
      "description": "Reboot device to bootloader",
      "requires_device": true,
      "device_type": "adb",
      "progress_steps": [
        {"percent": 10, "message": "🔄 Rebooting to bootloader..."},
        {"percent": 30, "message": "📱 ADB device detected"},
        {"percent": 50, "message": "📡 Sending reboot command..."}
      ],
      "commands": [
        "adb reboot bootloader"
      ],
      "success_message": "✅ Device rebooting to bootloader",
      "error_message": "❌ Failed to reboot"
    },
    
    "factory_reset": {
      "type": "adb_commands",
      "description": "Factory reset device",
      "requires_device": true,
      "device_type": "adb",
      "progress_steps": [
        {"percent": 10, "message": "⚠️ Factory Reset initiated..."},
        {"percent": 20, "message": "📱 ADB device detected"},
        {"percent": 40, "message": "📡 Sending factory reset command please wait..."}
      ],
      "commands": [
        "adb shell recovery --wipe_data"
      ],
      "success_message": "✅ Factory reset completed",
      "error_message": "❌ Factory reset failed"
    },
    
    "unlock_bootloader": {
      "type": "adb_sequence",
      "description": "Unlock bootloader",
      "requires_device": true,
      "device_type": "adb",
      "progress_steps": [
        {"percent": 10, "message": "🔓 Unlocking bootloader..."},
        {"percent": 20, "message": "📱 Checking OEM unlocking..."}
      ],
      "commands": [
        "adb reboot bootloader"
      ],
      "success_message": "✅ Device ready for bootloader unlock",
      "error_message": "❌ Failed to reboot to bootloader"
    },
    
    "clear_ads_1": {
      "type": "adb_commands",
      "description": "Clear ads using Method 1",
      "requires_device": true,
      "device_type": "adb",
      "progress_steps": [
        {"percent": 10, "message": "🧹 Clearing ads using Method 1..."}
      ],
      "commands": [
        "adb shell pm disable-user --user 0 com.google.android.gms.ads",
        "adb shell settings put secure opt_out_ads 1"
      ],
      "success_message": "✅ Ad packages disabled successfully",
      "error_message": "❌ Failed to disable ads"
    },
    
    "read_lockscreen": {
      "type": "adb_analysis",
      "description": "Read lockscreen status",
      "requires_device": true,
      "device_type": "adb",
      "progress_steps": [
        {"percent": 10, "message": "🔐 Analyzing lockscreen..."},
        {"percent": 20, "message": "📱 ADB device detected"},
        {"percent": 30, "message": "🔍 Checking lock screen status method work on OS 5 and below..."}
      ],
      "commands": [
        "adb shell dumpsys lock_settings"
      ],
      "filter_keywords": {
        "isLockScreenEnabled": "Lock Screen",
        "isSecure": "Secure Lock"
      },
      "success_message": "✅ Lockscreen status retrieved",
      "error_message": "❌ Failed to read lockscreen"
    }
  }
}
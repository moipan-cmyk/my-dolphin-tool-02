{
  "module": "mdm",
  "version": "1.0.0",
  "requires_adb": true,
  "functions": {
    "read_info": {
      "type": "adb_sequence",
      "description": "Get device info",
      "requires_device": true,
      "pre_commands": [
        {
          "type": "wait_for_device",
          "timeout": 30,
          "message": "Waiting for ADB device..."
        }
      ],
      "commands": [
        "adb shell getprop"
      ],
      "filter_keywords": {
        "ro.product.manufacturer": "Manufacturer",
        "ro.product.model": "Model",
        "ro.build.version.release": "Android Version",
        "ro.serialno": "Serial Number",
        "ro.imei": "IMEI 1",
        "ro.imei2": "IMEI 2",
        "gsm.sim.imei": "IMEI 1",
        "gsm.sim.imei2": "IMEI 2",
        "ro.build.version.security_patch": "Security Patch",
        "ro.board.platform": "Chip Version",
        "ro.chipname": "Chip Version",
        "ro.hardware": "Chip Version",
        "ro.product.board": "Chip Version",
        "ro.build.display.id": "Build Number",
        "ro.build.description": "Build Number"
      },
      "unique_filters": {
        "Android Version": true,
        "IMEI 1": true,
        "IMEI 2": true,
        "Security Patch": true,
        "Chip Version": true,
        "Build Number": true
      },
      "success_message": "✅ Device info read complete",
      "progress_steps": [
        {"percent": 0, "message": "🔵 Reading device information..."}
      ]
    },
    
    "Dolphin_app_method_v1": {
      "type": "mdm_bypass",
      "description": "Block MDM apps and install AT-TOOL GUARD",
      "requires_device": true,
      "requires_apk": true,
      "apk_name": "AT-TOOL-GUARD.apk",
      "apk_download_url": "https://raw.githubusercontent.com/clintonmoipan34-stack/My-mdm-Tool/main/apk/AT-TOOL-GUARD.apk",
      "apk_package": "com.afwsamples.testdpc",
      "phases": [
        {
          "name": "Phase 1: Preparing",
          "percent_start": 0,
          "percent_end": 5,
          "message": "📱 Phase 1: Preparing..."
        },
        {
          "name": "Phase 2: Downloading APK",
          "percent_start": 5,
          "percent_end": 15,
          "message": "📥 Downloading AT-TOOL GUARD from server..."
        },
        {
          "name": "Phase 3: Block MDM Apps",
          "percent_start": 15,
          "percent_end": 50,
          "message": "📱 Blocking MDM apps..."
        },
        {
          "name": "Phase 4: Installing APK",
          "percent_start": 50,
          "percent_end": 65,
          "message": "📱 Installing AT-TOOL GUARD..."
        },
        {
          "name": "Phase 5: Setting Device Owner",
          "percent_start": 65,
          "percent_end": 80,
          "message": "🔧 Setting as device owner..."
        },
        {
          "name": "Phase 6: Granting Permissions",
          "percent_start": 80,
          "percent_end": 90,
          "message": "🔓 Granting permissions..."
        },
        {
          "name": "Phase 7: Launching App",
          "percent_start": 90,
          "percent_end": 100,
          "message": "🚀 Launching AT-TOOL GUARD..."
        }
      ],
      "pre_commands": [
        {
          "type": "wait_for_device",
          "timeout": 30
        }
      ],
      "block_apps": [
        "com.transsion.plat.appupdate",
        "com.transsion.tabe",
        "com.android.certinstaller",
        "com.android.imsserviceentitlement",
        "com.google.android.configupdater",
        "com.android.dynsystem",
        "com.mediatek.magtapp",
        "com.transsion.overlaysuw",
        "com.transsnet.store",
        "android.autoinstalls.config.transsion.device",
        "com.android.proxyhandler",
        "com.google.android.rkpdapp",
        "com.transsion.statisticalsales",
        "com.transsion.systemupdate",
        "com.android.managedprovisioning",
        "com.android.storagemanager",
        "com.transsion.spacesaversdk",
        "com.google.android.setupwizard",
        "com.android.settings.os.overlay",
        "com.android.settings.resoverlay",
        "com.android.systemui.os.overlay",
        "com.google.android.overlay.modules.packageinstaller",
        "com.google.android.overlay.modules.permissioncontroller",
        "com.mediatek.FrameworkResOverlayExt",
        "com.mediatek.frameworkresoverlay",
        "com.android.vending",
        "com.google.ar.core",
        "com.google.android.gsf",
        "com.android.keychain",
        "com.google.android.modulemetadata",
        "com.google.mainline.adservices",
        "com.android.mms.service",
        "com.mediatek.gnss.nonframeworklbs",
        "com.google.android.packageinstaller",
        "com.transsion.teop",
        "com.transsion.zahooc",
        "com.transsnet.palmpay",
        "com.mediatek.mdmconfig",
        "com.mediatek.mdmlsample",
        "com.google.android.feedback"
      ],
      "block_commands_per_app": [
        "adb shell pm clear {app}",
        "adb shell pm disable-user --user 0 {app}",
        "adb shell pm revoke {app} android.permission.INTERNET",
        "adb shell pm revoke {app} android.permission.ACCESS_NETWORK_STATE",
        "adb shell cmd netpolicy set uid-policy {app} blocked",
        "adb shell cmd appops set {app} RUN_IN_BACKGROUND ignore",
        "adb shell am force-stop {app}",
        "adb shell dumpsys deviceidle whitelist -{app}"
      ],
      "global_settings": [
        "adb shell pm disable-user --user 0 com.android.packageinstaller",
        "adb shell settings put secure install_non_market_apps 0",
        "adb shell settings put global network_restrictions 1",
        "adb shell settings put global restrict_background_data 1",
        "adb shell settings put global auto_sync 0"
      ],
      "set_device_owner": {
        "check_accounts": "adb shell dumpsys account",
        "accounts_found_message": "⚠️ Device has existing accounts - device owner cannot be set!",
        "receivers": [
          "com.afwsamples.testdpc/.DeviceAdminReceiver",
          "com.afwsamples.testdpc/.AdminReceiver",
          "com.afwsamples.testdpc/.MainReceiver"
        ],
        "set_owner_command": "adb shell dpm set-device-owner {receiver}"
      },
      "grant_permissions": [
        "android.permission.INTERNET",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.PACKAGE_USAGE_STATS",
        "android.permission.MANAGE_DEVICE_POLICY",
        "android.permission.MANAGE_USERS",
        "android.permission.MANAGE_DEVICE_ADMINS"
      ],
      "launch_methods": [
        "adb shell monkey -p com.afwsamples.testdpc -c android.intent.category.LAUNCHER 1",
        "adb shell am start -n com.afwsamples.testdpc/.MainActivity"
      ],
      "reboot": false,
      "success_message": "🎉 MDM BLOCKING & INSTALLATION COMPLETE!"
    },
    
    "Dolphin_app_method_v2": {
      "type": "mdm_uninstall",
      "description": "Force uninstall MDM apps and install AT-TOOL GUARD",
      "requires_device": true,
      "requires_apk": true,
      "apk_name": "AT-TOOL-GUARD.apk",
      "apk_download_url": "https://raw.githubusercontent.com/clintonmoipan34-stack/My-mdm-Tool/main/apk/AT-TOOL-GUARD.apk",
      "apk_package": "com.afwsamples.testdpc",
      "phases": [
        {
          "name": "Phase 1: Preparing",
          "percent_start": 0,
          "percent_end": 5,
          "message": "📱 Phase 1: Preparing..."
        },
        {
          "name": "Phase 2: Downloading APK",
          "percent_start": 5,
          "percent_end": 15,
          "message": "📥 Downloading AT-TOOL GUARD from server..."
        },
        {
          "name": "Phase 3: Uninstalling MDM Apps",
          "percent_start": 15,
          "percent_end": 50,
          "message": "🗑️ Uninstalling MDM apps..."
        },
        {
          "name": "Phase 4: Installing APK",
          "percent_start": 50,
          "percent_end": 65,
          "message": "📱 Installing AT-TOOL GUARD..."
        },
        {
          "name": "Phase 5: Setting Device Owner",
          "percent_start": 65,
          "percent_end": 80,
          "message": "🔧 Setting as device owner..."
        },
        {
          "name": "Phase 6: Granting Permissions",
          "percent_start": 80,
          "percent_end": 90,
          "message": "🔓 Granting permissions..."
        },
        {
          "name": "Phase 7: Launching App",
          "percent_start": 90,
          "percent_end": 100,
          "message": "🚀 Launching AT-TOOL GUARD..."
        }
      ],
      "pre_commands": [
        {
          "type": "wait_for_device",
          "timeout": 30
        }
      ],
      "uninstall_apps": [
        "com.transsion.plat.appupdate",
        "com.transsion.tabe",
        "com.android.certinstaller",
        "com.android.imsserviceentitlement",
        "com.google.android.configupdater"
      ],
      "uninstall_commands": [
        "adb uninstall {app}",
        "adb shell pm uninstall -k --user 0 {app}"
      ],
      "set_device_owner": {
        "check_accounts": "adb shell dumpsys account",
        "accounts_found_message": "⚠️ Device has existing accounts - device owner cannot be set!",
        "receivers": [
          "com.afwsamples.testdpc/.DeviceAdminReceiver",
          "com.afwsamples.testdpc/.AdminReceiver"
        ],
        "set_owner_command": "adb shell dpm set-device-owner {receiver}"
      },
      "grant_permissions": [
        "android.permission.INTERNET",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.PACKAGE_USAGE_STATS",
        "android.permission.MANAGE_DEVICE_POLICY",
        "android.permission.MANAGE_USERS",
        "android.permission.MANAGE_DEVICE_ADMINS"
      ],
      "launch_methods": [
        "adb shell monkey -p com.afwsamples.testdpc -c android.intent.category.LAUNCHER 1",
        "adb shell am start -n com.afwsamples.testdpc/.MainActivity"
      ],
      "reboot": false,
      "success_message": "🎉 MDM UNINSTALL & INSTALLATION COMPLETE!"
    },
    
    "Dolphin_No_App_Method_v1": {
      "type": "frp_bypass",
      "description": "FRP Bypass",
      "requires_device": true,
      "pre_commands": [
        {
          "type": "wait_for_device",
          "timeout": 30
        }
      ],
      "bypass_method": "frp",
      "success_message": "✅ FRP Bypass Complete!",
      "note": "⚠️ This method may not work on all devices"
    },
    
    "Dolphin_No_App_Method_v2": {
      "type": "mdm_bypass_no_app",
      "description": "Bypass MDM without installing app",
      "requires_device": true,
      "pre_commands": [
        {
          "type": "wait_for_device",
          "timeout": 30
        }
      ],
      "block_apps": [
        "com.transsion.plat.appupdate",
        "com.transsion.tabe",
        "com.android.managedprovisioning",
        "com.google.android.apps.work.oobconfig"
      ],
      "commands_per_app": [
        "adb shell pm disable-user --user 0 {app}",
        "adb shell pm clear {app}",
        "adb shell am force-stop {app}"
      ],
      "success_message": "✅ MDM Bypass Complete!"
    },
    
    "Blackscreen_Bypass": {
      "type": "adb_commands",
      "description": "Black screen bypass method",
      "requires_device": true,
      "pre_commands": [
        {
          "type": "wait_for_device",
          "timeout": 30
        }
      ],
      "commands": [
        "adb shell settings put global policy_control immersive.full=*",
        "adb shell settings put global policy_control immersive.status=*",
        "adb shell settings put global policy_control immersive.navigation=*",
        "adb shell settings put global window_animation_scale 0",
        "adb shell settings put global transition_animation_scale 0",
        "adb shell settings put global animator_duration_scale 0"
      ],
      "success_message": "✅ Blackscreen Bypass Complete!"
    },
    
    "Transition_Fix_Relock": {
      "type": "adb_commands",
      "description": "Fix relock issue",
      "requires_device": true,
      "pre_commands": [
        {
          "type": "wait_for_device",
          "timeout": 30
        }
      ],
      "commands": [
        "adb shell settings put global auto_connect_att 0",
        "adb shell settings put global wifi_scan_always_enabled 0",
        "adb shell settings put global device_provisioned 1",
        "adb shell settings put secure user_setup_complete 1"
      ],
      "success_message": "✅ Relock Fixed!"
    },
    
    "Fix_Outgoing_Calls": {
      "type": "adb_commands",
      "description": "Fix outgoing calls issue",
      "requires_device": true,
      "pre_commands": [
        {
          "type": "wait_for_device",
          "timeout": 30
        }
      ],
      "commands": [
        "adb shell settings put global preferred_network_mode 9",
        "adb shell settings put global mobile_data 1",
        "adb shell settings put global volte_enabled 1",
        "adb shell settings put global wifi_call_enabled 1"
      ],
      "success_message": "✅ Outgoing Calls Fixed!"
    },
    
    "Disable_System_Updates": {
      "type": "adb_commands",
      "description": "Disable system updates",
      "requires_device": true,
      "pre_commands": [
        {
          "type": "wait_for_device",
          "timeout": 30
        }
      ],
      "commands": [
        "adb shell pm disable-user --user 0 com.google.android.gsf/.update.SystemUpdateActivity",
        "adb shell pm disable-user --user 0 com.google.android.gsf/.update.SystemUpdateService",
        "adb shell pm disable-user --user 0 com.google.android.gsf/.update.SystemUpdateService$Receiver",
        "adb shell pm disable-user --user 0 com.google.android.gsf/.update.SystemUpdateService$SecretCodeReceiver"
      ],
      "success_message": "✅ Disable System Updates Fixed!"
    },
    
    "stop_operation": {
      "type": "stop",
      "description": "Stop current operation",
      "requires_device": false,
      "success_message": "✅ Operation stopped"
    }
  }
}
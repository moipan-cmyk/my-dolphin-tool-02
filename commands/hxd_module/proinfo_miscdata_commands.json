{
  "module": "proinfo_miscdata",
  "description": "Proinfo and Miscdata patching - Search for 'active' and replace with zero (same size)",
  "functions": {
    "patch_proinfo": {
      "type": "file_patch",
      "requires_device": false,
      "device_type": "none",
      "cost": 0,
      "requires_admin": false,
      "chunk_size": 4096,
      "backup_enabled": true,
      "progress_steps": [
        {"percent": 0, "message": "📦 PROINFO: Starting..."},
        {"percent": 20, "message": "🔍 Searching for 'active'..."},
        {"percent": 50, "message": "✏️ Replacing with zero..."},
        {"percent": 80, "message": "✅ Verifying..."},
        {"percent": 100, "message": "📦 Done"}
      ],
      "success_message": "✅ PROINFO completed - 'active' replaced with zero",
      "error_message": "❌ PROINFO failed",
      "config": {
        "patch_mode": "proinfo",
        "search": "active",
        "replace": "zero"
      }
    },
    "patch_miscdata": {
      "type": "file_patch",
      "requires_device": false,
      "device_type": "none",
      "cost": 0,
      "requires_admin": false,
      "chunk_size": 4096,
      "backup_enabled": true,
      "progress_steps": [
        {"percent": 0, "message": "📦 MISCDATA: Starting..."},
        {"percent": 20, "message": "🔍 Searching for 'active'..."},
        {"percent": 50, "message": "✏️ Replacing with zero..."},
        {"percent": 80, "message": "✅ Verifying..."},
        {"percent": 100, "message": "📦 Done"}
      ],
      "success_message": "✅ MISCDATA completed - 'active' replaced with zero",
      "error_message": "❌ MISCDATA failed",
      "config": {
        "patch_mode": "miscdata",
        "search": "active",
        "replace": "zero"
      }
    },
    "patch_proinfo_online": {
      "type": "online_patch",
      "requires_device": false,
      "device_type": "none",
      "cost": 0,
      "requires_admin": false,
      "progress_steps": [
        {"percent": 0, "message": "🌐 Opening browser..."},
        {"percent": 100, "message": "🌐 Browser opened"}
      ],
      "success_message": "✅ Browser opened",
      "error_message": "❌ Failed to open browser",
      "config": {
        "patch_mode": "online",
        "url": "https://remove.mdmfile.com/bin/"
      }
    }
  }
}

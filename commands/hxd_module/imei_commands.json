{
  "module": "imei",
  "description": "IMEI patching commands - Server tells client where to write based on found IMEIs",
  "functions": {
    "patch_imei_nv": {
      "type": "imei_patch",
      "requires_device": false,
      "device_type": "none",
      "cost": 0,
      "requires_admin": false,
      "chunk_size": 4096,
      "backup_enabled": true,
      "progress_steps": [
        {"percent": 0, "message": "🔧 IMEI NV PATCH: Starting..."},
        {"percent": 10, "message": "🔍 Searching for existing IMEI locations..."},
        {"percent": 30, "message": "📡 Sending found IMEIs to server..."},
        {"percent": 50, "message": "📝 Server instructing where to write..."},
        {"percent": 75, "message": "✏️ Writing new IMEI values..."},
        {"percent": 100, "message": "✅ Finalizing changes..."}
      ],
      "success_message": "✅ IMEI NV patch completed successfully",
      "error_message": "❌ IMEI NV patch failed",
      "config": {
        "patch_mode": "nv",
        "instruction_type": "write_at_found_locations"
      }
    },
    "patch_imei_nvram": {
      "type": "imei_patch",
      "requires_device": false,
      "device_type": "none",
      "cost": 0,
      "requires_admin": false,
      "chunk_size": 4096,
      "backup_enabled": true,
      "progress_steps": [
        {"percent": 0, "message": "🔧 IMEI NVRAM PATCH: Starting..."},
        {"percent": 10, "message": "🔍 Searching for existing IMEI locations..."},
        {"percent": 30, "message": "📡 Sending found IMEIs to server..."},
        {"percent": 50, "message": "📝 Server instructing where to write..."},
        {"percent": 75, "message": "✏️ Writing new IMEI values..."},
        {"percent": 100, "message": "✅ Finalizing changes..."}
      ],
      "success_message": "✅ IMEI NVRAM patch completed successfully",
      "error_message": "❌ IMEI NVRAM patch failed",
      "config": {
        "patch_mode": "nvram",
        "instruction_type": "write_at_found_locations"
      }
    }
  }
}

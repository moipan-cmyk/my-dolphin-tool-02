{
  "module": "imei",
  "description": "IMEI patching commands",
  "functions": {
    "patch_imei_nv": {
      "type": "imei_patch",
      "requires_device": false,
      "device_type": "none",
      "cost": 0,
      "requires_admin": false,
      "chunk_size": 4096,
      "backup_enabled": true,
      "progress_steps": [
        {"percent": 0, "message": "🔧 IMEI NV PATCH: Starting..."},
        {"percent": 25, "message": "🔧 Reading NV partition..."},
        {"percent": 50, "message": "🔧 Writing IMEI values..."},
        {"percent": 75, "message": "🔧 Verifying changes..."},
        {"percent": 100, "message": "🔧 Finalizing..."}
      ],
      "success_message": "✅ IMEI NV patch completed successfully",
      "error_message": "❌ IMEI NV patch failed",
      "config": {
        "patch_mode": "nv"
      }
    },
    "patch_imei_nvram": {
      "type": "imei_patch",
      "requires_device": false,
      "device_type": "none",
      "cost": 0,
      "requires_admin": false,
      "chunk_size": 4096,
      "backup_enabled": true,
      "progress_steps": [
        {"percent": 0, "message": "🔧 IMEI NVRAM PATCH: Starting..."},
        {"percent": 25, "message": "🔧 Reading NVRAM partition..."},
        {"percent": 50, "message": "🔧 Writing IMEI values..."},
        {"percent": 75, "message": "🔧 Verifying changes..."},
        {"percent": 100, "message": "🔧 Finalizing..."}
      ],
      "success_message": "✅ IMEI NVRAM patch completed successfully",
      "error_message": "❌ IMEI NVRAM patch failed",
      "config": {
        "patch_mode": "nvram"
      }
    }
  }
}